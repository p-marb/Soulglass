{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimal Glass Editor",
  "version": "0.1.0",
  "identifier": "com.local.minimal-glass-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Soulglass",
        "label": "main",
        "width": 1200,
        "height": 760,
        "minWidth": 820,
        "minHeight": 520,
        "transparent": true,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
